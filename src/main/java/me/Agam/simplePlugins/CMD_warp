package me.Agam.simplePlugins;

import org.bukkit.Bukkit;
import org.bukkit.Location;
import org.bukkit.World;
import org.bukkit.command.Command;
import org.bukkit.command.CommandExecutor;
import org.bukkit.command.CommandSender;
import org.bukkit.entity.Player;
import org.bukkit.plugin.java.JavaPlugin;

public class CMD_warp implements CommandExecutor {

    @Override
    public boolean onCommand(CommandSender sender, Command command, String label, String[] args) {

        SimplePlugins plugin = JavaPlugin.getPlugin(SimplePlugins.class);

        if (!(sender instanceof Player)) {
            sender.sendMessage("הפקודה יכולה להיות משומשת על ידי שחקן בלבד!");
            return false;
        }

        if (args.length == 0) {
            sender.sendMessage("אתה צריך להזין מזהה לווארפ כדי להשתגר אליו");
            return false;
        }

        if (args.length >= 2){
            sender.sendMessage("אינך יכול להזין יותר ממזהה אחת");
            return false;
        }

        if (!plugin.getWarpsConfig().contains("warps." + args[0])) {
            sender.sendMessage("אין ווארפ עם המזהה הזה!");
            return false;
        }

        Player player = (Player) sender;
        String id = args[0];
        String worldName = plugin.getWarpsConfig().getString("warps." + id + ".world");
        double x = plugin.getWarpsConfig().getDouble("warps." + id + ".x");
        double y = plugin.getWarpsConfig().getDouble("warps." + id + ".y");
        double z = plugin.getWarpsConfig().getDouble("warps." + id + ".z");
        float yaw = (float) plugin.getWarpsConfig().getDouble("warps." + id + ".yaw");
        float pitch = (float) plugin.getWarpsConfig().getDouble("warps." + id + ".pitch");

        World world = Bukkit.getWorld(worldName);
        if (world == null) {
            sender.sendMessage("העולם של הווארפ לא קיים!");
            return false;
        }

        Location loc = new Location(world, x, y, z, yaw, pitch);
        player.teleport(loc);
        sender.sendMessage("השתגרת לווארפ " + id + " בהצלחה!");
        return true;
    }
}
